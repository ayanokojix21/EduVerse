## ── App ───────────────────────────────────────────────────────────────────
APP_NAME=EduVerse Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
FRONTEND_ORIGIN=http://localhost:3000

## ── MongoDB Atlas ─────────────────────────────────────────────────────────
# URL-encode password if it contains special characters (@, :, /, etc.)
MONGO_URI=your_mongo_uri
MONGO_DB_NAME=eduverse
MONGO_OAUTH_TOKENS_COLLECTION=oauth_tokens
MONGO_CHILD_CHUNKS_COLLECTION=course_chunks_child
MONGO_PARENT_CHUNKS_COLLECTION=course_chunks_parent
MONGO_SEMANTIC_CACHE_COLLECTION=semantic_cache
MONGO_USER_PROFILES_COLLECTION=user_profiles
MONGO_TAVILY_USAGE_COLLECTION=tavily_usage
MONGO_CHECKPOINTS_COLLECTION=checkpoints
MONGO_CHECKPOINT_WRITES_COLLECTION=checkpoint_writes

# Atlas search index names (must match names used in setup_indexes.py)
MONGO_CHILD_VECTOR_INDEX_NAME=child_vector_index
MONGO_CHILD_BM25_INDEX_NAME=child_bm25_index
MONGO_SEMANTIC_CACHE_VECTOR_INDEX_NAME=cache_vector_index

# LangChain Indexing API dedup cache (SQLite, relative to backend/)
RECORD_MANAGER_DB_URL=sqlite:///record_manager_cache.db

## ── JWT (app-level authentication) ───────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

## ── OAuth token encryption (Fernet) ──────────────────────────────────────
FERNET_KEY=replace-with-generated-fernet-key

## ── Internal API secret (NextAuth → backend token storage) ───────────────
INTERNAL_API_SECRET=replace-with-random-64-char-string

## ── Google OAuth (Classroom + Drive scopes) ───────────────────────────────
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-replace-with-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8765/
# Gemini API key — for vision fallback (free tier)
GOOGLE_API_KEY=AIza-replace-with-google-api-key

## ── Groq (all agent models + vision) ─────────────────────────────────────
GROQ_API_KEY=gsk_replace-with-groq-api-key
GROQ_VISION_ENABLED=true
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_TEMPERATURE=0.0
GROQ_VISION_MAX_TOKENS=1024

# Agent LLM model overrides (optional — defaults are set in config.py)
GROQ_SUPERVISOR_MODEL=llama-3.1-8b-instant
GROQ_REWRITER_MODEL=llama-3.3-70b-versatile
GROQ_TUTOR_A_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TUTOR_B_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_SYNTHESIZER_MODEL=llama-3.3-70b-versatile
GROQ_CRITIC_MODEL=llama-3.3-70b-versatile

## ── Nomic embeddings ─────────────────────────────────────────────────────
NOMIC_API_KEY=nk-replace-with-nomic-api-key
NOMIC_EMBEDDING_MODEL=nomic-embed-text-v1.5

## ── Chunking ─────────────────────────────────────────────────────────────
PARENT_CHUNK_SIZE=800
CHILD_CHUNK_SIZE=200
CHUNK_OVERLAP=30

## ── Retrieval ─────────────────────────────────────────────────────────────
RETRIEVAL_K=20
RERANKER_TOP_N=5
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# Web fallback
TAVILY_THRESHOLD=0.35
TAVILY_DAILY_LIMIT=100
TAVILY_API_KEY=tvly-replace-with-tavily-api-key

## ── LangSmith observability ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=langsmit_endpoints
LANGSMITH_API_KEY=replace-with-langsmith-api-key
LANGCHAIN_PROJECT=eduverse-v11