## ── App ───────────────────────────────────────────────────────────────────
APP_NAME=EduVerse Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
FRONTEND_ORIGIN=http://localhost:3000

## ── MongoDB (Local) ───────────────────────────────────────────────────────
MONGO_URI=your_mongo_uri
MONGO_DB_NAME=eduverse
MONGO_OAUTH_TOKENS_COLLECTION=oauth_tokens
MONGO_CHILD_CHUNKS_COLLECTION=child_chunks
MONGO_PARENT_CHUNKS_COLLECTION=parent_chunks
MONGO_SEMANTIC_CACHE_COLLECTION=semantic_cache
MONGO_USER_PROFILES_COLLECTION=user_profiles
MONGO_TAVILY_USAGE_COLLECTION=tavily_usage
MONGO_CHECKPOINTS_COLLECTION=checkpoints
MONGO_CHECKPOINT_WRITES_COLLECTION=checkpoint_writes

# Atlas search index names 
MONGO_CHILD_VECTOR_INDEX_NAME=child_vector_index
MONGO_CHILD_BM25_INDEX_NAME=child_bm25_index
MONGO_SEMANTIC_CACHE_VECTOR_INDEX_NAME=cache_vector_index

# LangChain Indexing API dedup cache 
RECORD_MANAGER_DB_URL=sqlite:///record_manager_cache.db

## ── JWT (app-level authentication) ───────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

## ── OAuth token encryption (Fernet) ──────────────────────────────────────
FERNET_KEY=replace-with-generated-fernet-key

## ── Internal API secret (NextAuth → backend token storage) ───────────────
INTERNAL_API_SECRET=replace-with-random-64-char-string

## ── Google OAuth (Classroom + Drive scopes) ───────────────────────────────
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8765/
GOOGLE_API_KEY=replace-with-google-api-key

## ── LLM Provider ─────────────────────────────────────────────────────────
LLM_PROVIDER=local

## ── Ollama (Local Inference - Gemma 4) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_NUM_THREADS=8
LOCAL_CONTEXT_WINDOW=131072
LOCAL_ORCHESTRATOR_MODEL=gemma4:e4b
LOCAL_TUTOR_MODEL=gemma4:e4b
LOCAL_QUIZ_MODEL=gemma4:e4b
LOCAL_FEEDBACK_MODEL=gemma4:e4b
LOCAL_CRITIC_MODEL=gemma4:e4b
LOCAL_VISION_MODEL=gemma4:e4b

## ── Gemini (Optional Cloud Fallback) ─────────────────────────────────────
# Task-optimized model assignment:
GEMINI_ORCHESTRATOR_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TUTOR_MODEL=gemini-3-flash-preview
GEMINI_QUIZ_MODEL=gemini-3-flash-preview
GEMINI_FEEDBACK_MODEL=gemini-3-flash-preview
GEMINI_CRITIC_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

## ── Autonomous Training (Beast Mode) ──────────────────────────────────────
# Kaggle execution credentials
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
KAGGLE_KERNEL_SLUG=eduverse-dpo-trainer

# Quality Gate Settings
EVAL_JUDGE_MODEL=gemini-2.5-pro
BENCHMARK_SET_SIZE=100
MIN_DPO_PAIRS_FOR_TRAINING=150
IMPROVEMENT_THRESHOLD=0.15

# Training Registry
AUTO_PROMOTE_MODELS=true
LOCAL_ADAPTERS_PATH=./local_weights

## ── Groq (Secondary Cloud Fallback) ──────────────────────────────────────
GROQ_API_KEY=gsk_replace-with-groq-api-key
GROQ_VISION_ENABLED=true
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_TEMPERATURE=0.0
GROQ_VISION_MAX_TOKENS=1024

# Agent LLM model overrides for Groq fallback (optional)
GROQ_ORCHESTRATOR_MODEL=llama-3.1-8b-instant
GROQ_TUTOR_MODEL=llama-3.3-70b-versatile
GROQ_QUIZ_MODEL=llama-3.3-70b-versatile
GROQ_FEEDBACK_MODEL=llama-3.3-70b-versatile
GROQ_CRITIC_MODEL=llama-3.3-70b-versatile

## ── Local RAG & Embeddings ───────────────────────────────────────────────
LOCAL_EMBEDDING_MODEL=snowflake/snowflake-arctic-embed-m-long
LOCAL_RERANKER_MODEL=ms-marco-MiniLM-L-6-v2

## ── Nomic embeddings (Optional Cloud Fallback) ───────────────────────────
NOMIC_API_KEY=replace-with-nomic-api-key
NOMIC_EMBEDDING_MODEL=nomic-embed-text-v1.5

## ── Chunking ─────────────────────────────────────────────────────────────
PARENT_CHUNK_SIZE=4000
CHILD_CHUNK_SIZE=1000
CHUNK_OVERLAP=200

## ── Retrieval ─────────────────────────────────────────────────────────────
RETRIEVAL_K=150
RERANKER_TOP_N=100
RERANKER_MODEL=rerank-v3.5

## ── Sandboxing & Web Search ───────────────────────────────────────────────
E2B_API_KEY=replace-with-e2b-api-key
SERPER_API_KEY=replace-with-serper-api-key

## ── LangSmith observability ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=langsmith_endpoints
LANGSMITH_API_KEY=replace-with-langsmith-api-key
LANGCHAIN_PROJECT=eduverse