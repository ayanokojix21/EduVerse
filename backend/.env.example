## ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=EduVerse Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
FRONTEND_ORIGIN=https://your-frontend.vercel.app

## ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.5zuv6f5.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=eduverse
MONGO_OAUTH_TOKENS_COLLECTION=oauth_tokens
MONGO_CHILD_CHUNKS_COLLECTION=child_chunks
MONGO_PARENT_CHUNKS_COLLECTION=parent_chunks
MONGO_SEMANTIC_CACHE_COLLECTION=semantic_cache
MONGO_USER_PROFILES_COLLECTION=user_profiles

# Atlas search index names
MONGO_CHILD_VECTOR_INDEX_NAME=vector_index
MONGO_CHILD_BM25_INDEX_NAME=text_index
MONGO_SEMANTIC_CACHE_VECTOR_INDEX_NAME=cache_index

## ── JWT (app-level authentication) ────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

## ── OAuth token encryption (Fernet) ───────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key

## ── Internal API secret (NextAuth -> backend token storage) ───────────────────
INTERNAL_API_SECRET=replace-with-random-64-char-string

## ── Google OAuth (Classroom + Drive scopes) ────────────────────────────────────
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URL=https://your-frontend.vercel.app/api/auth/callback/google
GOOGLE_API_KEY=replace-with-google-api-key

## ── Cloud LLM (Gemma 4 via Google AI Studio) ──────────────────────────────────
# Tier 1: Routing & Guardrails (Extremely fast, edge optimized)
GEMMA_ROUTING_MODEL=gemma-4-e4b-it
# Tier 2: Parallel Swarms & Fast Reasoning (MoE)
GEMMA_FAST_REASONING_MODEL=gemma-4-26b-it
# Tier 3: Deep Pedagogical Reasoning (Dense)
GEMMA_HEAVY_REASONING_MODEL=gemma-4-31b-it

## ── Cloud Teacher / DPO Judge (Gemini 2.5 Pro) ────────────────────────────────
EVAL_JUDGE_MODEL=gemini-2.5-pro

## ── Cloudinary (Document Storage) ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret

## ── Nomic (Cloud Embeddings) ──────────────────────────────────────────────────
NOMIC_API_KEY=replace-with-nomic-api-key
NOMIC_EMBEDDING_MODEL=nomic-embed-text-v1.5

## ── Cohere (Cloud Reranker) ───────────────────────────────────────────────────
COHERE_API_KEY=replace-with-cohere-api-key
RERANKER_MODEL=rerank-v3.5

## ── E2B (Cloud Code Sandbox) ──────────────────────────────────────────────────
E2B_API_KEY=replace-with-e2b-api-key

## ── Web Search (SerperDev) ────────────────────────────────────────────────────
SERPER_API_KEY=replace-with-serper-api-key

## ── Chunking ──────────────────────────────────────────────────────────────────
PARENT_CHUNK_SIZE=4000
CHILD_CHUNK_SIZE=1000
CHUNK_OVERLAP=200

## ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_K=150
RERANKER_TOP_N=100

## ── Autonomous Training (Kaggle + Hugging Face) ───────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
KAGGLE_KERNEL_SLUG=eduverse-dpo-trainer
HF_TOKEN=hf_your_write_token_here
AUTO_PROMOTE_MODELS=true
MIN_DPO_PAIRS_FOR_TRAINING=150
IMPROVEMENT_THRESHOLD=0.15
BENCHMARK_SET_SIZE=100

## ── LangSmith Observability ───────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=replace-with-langsmith-api-key
LANGCHAIN_PROJECT=EduVerse